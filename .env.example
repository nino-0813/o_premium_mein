# ---- サンプル・資料請求フォーム → Google スプレッドシート ----
# 1. Google Cloud でプロジェクト作成 → APIとサービス → 認証情報 → サービスアカウント作成 → キーを JSON で追加
# 2. Google Sheets API を有効化
# 3. スプレッドシートの「共有」で、サービスアカウントのメール（xxx@xxx.iam.gserviceaccount.com）を編集者として追加
# 4. スプレッドシートの 1 行目にヘッダーを入力: 受付日時, ご希望の内容, 医院名・法人名, ご担当者名, メールアドレス, 電話番号, 郵便番号, お届け先住所, ご質問・ご要望など

# サービスアカウントの JSON キー（ダブルクォートはエスケープ \" で記載するか、1行にまとめたJSON文字列）
GOOGLE_SHEETS_CREDENTIALS_JSON=""

# スプレッドシートの ID（URL の /d/ と /edit の間の文字列）
GOOGLE_SHEET_ID=""

# シート名（省略時は Sheet1）
# GOOGLE_SHEET_NAME="Sheet1"

# ---- Stripe（テスト決済）----
# 公開鍵（pk_test_...）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# シークレットキー（sk_test_...）※絶対にクライアントに露出させない
STRIPE_SECRET_KEY=""
